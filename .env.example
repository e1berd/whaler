# Local Supabase CLI defaults.
# Run `supabase status` after `supabase start` and copy the anon key here.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_PUBLIC_URL=http://127.0.0.1:54321
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key

API_PORT=3000
COLLAB_PORT=3001
RUNNER_PORT=3002
VITE_API_URL=http://localhost:3000
VITE_COLLAB_URL=ws://localhost:3001

RUNNER_INTERNAL_URL=http://localhost:3002
RUNNER_INTERNAL_TOKEN=change-me-to-a-long-random-token
DOCKER_SOCKET_PATH=/var/run/docker.sock
SANDBOX_MEMORY_BYTES=536870912
SANDBOX_NANO_CPUS=1000000000
SANDBOX_PIDS_LIMIT=256

# Docker Compose app stack. Use host.docker.internal when Supabase CLI runs on the host.
DATABASE_URL_DOCKER=postgres://postgres:postgres@host.docker.internal:54322/postgres
RUNNER_INTERNAL_URL_DOCKER=http://runner:3002

# Caddy domains. For Beget VDS production, point these DNS A records to the VDS IP
# and replace the localhost values with your real subdomains.
BASE_DOMAIN=localhost
APP_DOMAIN=localhost
API_DOMAIN=api.localhost
COLLAB_DOMAIN=collab.localhost
SUPABASE_DOMAIN=supabase.localhost
CADDY_ACME_EMAIL=admin@example.com
SUPABASE_UPSTREAM=host.docker.internal:54321

# Production example:
# BASE_DOMAIN=example.com
# APP_DOMAIN=app.example.com
# API_DOMAIN=api.example.com
# COLLAB_DOMAIN=collab.example.com
# SUPABASE_DOMAIN=supabase.example.com
# APP_ORIGIN=https://app.example.com
# VITE_API_URL=https://api.example.com
# VITE_COLLAB_URL=wss://collab.example.com
# VITE_SUPABASE_URL=https://supabase.example.com
