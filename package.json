{
  "name": "whaler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "pnpm -r --parallel --filter './apps/*' dev",
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' build",
    "typecheck": "pnpm -r --filter './packages/*' --filter './apps/*' typecheck",
    "db:generate": "pnpm --filter @whaler/db db:generate",
    "db:migrate": "pnpm --filter @whaler/db db:migrate"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["mediasoup"]
  }
}
